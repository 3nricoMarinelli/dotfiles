{
  // No model pinned — all agents inherit the active session model.
  // Switch models at runtime with /models or --model flag.
  "autoupdate": true,
  "default_agent": "plan",

  "$schema": "https://opencode.ai/config.json",
  "provider": {
      "github-copilot": {
          "options": {
              "timeout": 1200000,
              "chunkTimeout": 600000
          }
      },
      "llama.cpp": {
          "npm": "@ai-sdk/openai-compatible",
          "name": "llama-server (local)",
          "options": {
              "baseURL": "http://localhost:9090/v1"
          },
          "models": {
              "gemma-4": {
                  "name": "Gemma 4",
                  "limit": {
                      "context": 128000,
                      "output": 4096
                  }
              }
          }
      },
      "opencode": {
          "options": {
              "timeout": 1200000,
              "chunkTimeout": 600000
          }
      }
  },

  // === Permissions ===
  // Global permissions - uses ask/allow/deny pattern
  // Last matching rule wins
  "permission": {
      "external_directory": "ask",
      "bash": {
          "sudo *": "deny",
          "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      ":(){:|:&};:": "deny"
    }
  },

  // === Formatters ===
  // Domains: embedded (C/C++), Rust, mobile (Swift/Kotlin/Flutter/Go), robotics (Python/ROS)
  "formatter": {
    "clang-format": {
      "command": ["clang-format", "-i", "$FILE"],
      "extensions": [".c", ".cc", ".cpp", ".cxx", ".h", ".hpp", ".hxx", ".ino"]
    },
    "rustfmt": {
      "command": ["rustfmt", "$FILE"],
      "extensions": [".rs"]
    },
    "ruff": {
      "command": ["ruff", "format", "$FILE"],
      "extensions": [".py"]
    },
    "gofmt": {
      "command": ["gofmt", "-w", "$FILE"],
      "extensions": [".go"]
    },
    "swift-format": {
      "command": ["swift-format", "format", "--in-place", "$FILE"],
      "extensions": [".swift"]
    },
    "ktlint": {
      "command": ["ktlint", "--format", "$FILE"],
      "extensions": [".kt", ".kts"]
    }
  },

  // === MCP Servers ===
  // context7: library/SDK docs lookup (supports C++, Rust, Swift, Kotlin, Go, Python, ROS)
  // fetch: general web fetching for datasheets, specs, RFCs
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"]
    }
  },

  // === Agent Strategy ===
  //
  // PRIMARY AGENTS (Tab to cycle):
  //   build — full capability, orchestrates subagents in parallel swarms
  //   plan — read-only analysis, asks before any change
  //
  // SUBAGENTS (@mention or spawned via Task tool):
  //   See agents/ directory for full list
  //
  // DYNAMIC SCALING:
  //   Build (orchestrator) spawns N instances per role based on task scope — all parallel.
  //   Use swarm_* tools for parallel multi-agent coordination.
  //   No model is pinned anywhere.

  "agent": {
    // ─── PRIMARY: Build (Orchestrator) ────────────────────────────────────────────────
    // Override built-in build mode - enhanced orchestrator with swarm capabilities
    "build": {
      "description": "Orchestrator agent - coordinates subagent swarms, delegates work, manages task decomposition",
      "mode": "primary",
      "prompt": "{file:./agents/build.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "grep": true,
        "read": true,
        "task": true,
        "webfetch": true,
        "websearch": true,
        "codesearch": true,
        "patch": true,
        "TodoWrite": true,
        "question": true
      },
      "permission": {
        "task": { "*": "allow" },
        "swarm_*": "allow",
        "hive_*": "allow",
        "swarmmail_*": "allow",
        "hivemind_*": "allow",
        "cass_*": "allow",
        "ubs_*": "allow"
      }
    },

    // ─── PRIMARY: Plan (Analyzer) ─────────────────────────────────────────────────────
    // Override built-in plan mode - enhanced planner with task analysis
    "plan": {
      "description": "Task planning and analysis - read-only analysis, creates task breakdown",
      "mode": "primary",
      "prompt": "{file:./agents/plan.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "glob": true,
        "grep": true,
        "read": true,
        "task": true,
        "webfetch": true,
        "websearch": true,
        "codesearch": true,
        "question": true,
        "hive_*": true,
        "swarm_*": true
      },
      "permission": {
        "task": { "*": "allow" },
        "hive_*": "allow",
        "swarm_*": "allow"
      }
    },

    // ─── PRIMARY: Docs ─────────────────────────────────────────────────────────
    "docs": {
      "temperature": 0.3,
      "description": "Documentation writer - README, API docs, changelogs",
      "permission": {
        "write": {
          "**/*.md": "allow",
          "**/*.mdx": "allow",
          "**/*.rst": "allow",
          "*": "deny"
        },
        "task": { "*": "allow" },
        "swarm_*": "allow"
      }
    }
  }
}
